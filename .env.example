# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# In CI these are provided as GitHub Actions secrets, not from a file.

# --- LLM (summarization) ---
# Which key is read is controlled by `llm.api_key_env` in config.yaml.
# Default provider is Groq (free tier): https://console.groq.com/keys
GROQ_API_KEY=

# Only needed if you switch config.yaml to the Anthropic provider.
ANTHROPIC_API_KEY=

# --- Email delivery (Gmail SMTP) ---
# SMTP_USER is your Gmail address.
# SMTP_PASS must be a Gmail *App Password* (16 chars), NOT your account
# password. Create one at https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=
